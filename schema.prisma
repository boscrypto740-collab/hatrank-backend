// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AnalysisResult {
  id            String   @id @default(cuid())
  username      String   @unique
  
  // X Account Data
  displayName   String?
  bio           String?
  profileImage  String?
  verified      Boolean  @default(false)
  joinedAt      DateTime?
  
  // Metrics
  followersCount  Int     @default(0)
  followingCount  Int     @default(0)
  tweetCount      Int     @default(0)
  likeCount       Int     @default(0)
  
  // Activity Breakdown (%)
  originalTweetPct  Float @default(0)
  replyPct          Float @default(0)
  retweetPct        Float @default(0)
  quotePct          Float @default(0)
  
  // Computed Scores
  activityScore   Float   @default(0)   // 0–100
  engagementRate  Float   @default(0)
  
  // HatRank Badge
  hatLevel        Int     @default(1)   // 1–6
  hatTitle        String  @default("PHANTOM HAT")
  hatEmoji        String  @default("🎩")
  
  // AI Narrative
  aiAnalysis      String? @db.Text
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastFetchedAt   DateTime @default(now())
  
  @@index([username])
  @@index([hatLevel])
}
