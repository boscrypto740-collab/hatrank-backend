# ── X (Twitter) API v2 ──────────────────────────────
X_BEARER_TOKEN=your_x_bearer_token_here
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_SECRET=your_access_token_secret_here

# ── Anthropic Claude ─────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Database (PostgreSQL via Railway) ────────────────
DATABASE_URL=postgresql://user:password@host:5432/hatrank

# ── Redis (Railway Redis add-on) ─────────────────────
REDIS_URL=redis://default:password@host:6379

# ── App Config ───────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=https://your-frontend-url.vercel.app

# ── Cache TTL (seconds) ──────────────────────────────
CACHE_TTL_FRESH=3600       # 1 jam — hasil segar
CACHE_TTL_STALE=86400      # 24 jam — fallback jika X API error
